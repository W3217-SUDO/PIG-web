# EditorConfig · https://editorconfig.org
# 统一团队跨编辑器的缩进、换行、编码风格
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[*.{js,ts,vue,jsx,tsx}]
indent_size = 2

[Makefile]
indent_style = tab
