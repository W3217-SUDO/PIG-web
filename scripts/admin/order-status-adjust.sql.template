--   AND @target_status IN ('cancelled', 'refunded');

-- Verify before COMMIT.
SELECT
  o.id, o.status, o.pay_method, o.wx_pay_transaction_id,
  o.paid_at, o.shipped_at, o.delivered_at, o.refunded_at,
  o.refund_reason, o.tracking_no, o.remark, o.updated_at,
  p.id AS pig_id, p.sold_shares, p.total_shares, p.status AS pig_status
FROM `order` o
LEFT JOIN pig p ON p.id = o.pig_id
WHERE o.id = @order_id;

