# 依赖
node_modules/
.pnpm-store/
__pycache__/
*.pyc
.venv/
venv/

# 构建产物
dist/
build/
out/
.next/
.nuxt/
.output/
.cache/
.parcel-cache/
unpackage/

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 环境变量与密钥(绝不入库)
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.crt
config/secrets.*

# 编辑器/系统
.vscode/
.idea/
.claude/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# 上传/临时
uploads/
tmp/
temp/

# 微信小程序工具
.miniprogram/
project.private.config.json
# 每个开发者打开微信开发者工具后会本地生成此文件(含本地分配的测试 appid)
# 真正应入仓的设置在 frontend/src/manifest.json
project.config.json

# 本地数据库 / 数据文件
*.sqlite
*.db
data/

# HBuilderX(uni-app 真机调试用)
.hbuilderx/

# Workspace / IDE 配置
*.code-workspace
.history/

# 测试覆盖率
coverage/
.nyc_output/

# backend e2e 测试编译产物(ts-jest 在某些场景会生成,不入仓)
backend/test/**/*.js
backend/test/**/*.d.ts
backend/test/**/*.js.map
backend/test/**/*.d.ts.map
!backend/test/**/*.e2e-spec.ts
