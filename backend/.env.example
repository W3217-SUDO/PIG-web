# ============================================
# PIG 后端 · 环境变量模板
# 拷贝到 .env.development / .env.production 后填实际值
# ============================================

# ── 运行 ────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── 数据库 ──────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=local_dev_pass
DB_NAME=pig
DB_LOGGING=false
DB_SYNCHRONIZE=false

# ── Redis ────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# ── JWT ──────────────────────────────────────
JWT_SECRET=change_me_to_a_random_string_with_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ── 管理员账号(手机号 + 密码登录) ────────────
# 生产环境请改成真实账号 + 强密码,并通过 ssh 改服务器 .env
ADMIN_PHONE=13800000000
ADMIN_PASSWORD=admin123

# ── 微信小程序 ───────────────────────────────
WX_MP_APPID=wx_placeholder_appid
WX_MP_SECRET=placeholder_secret

# ── 微信开放平台(APP 用) ────────────────────
WX_OPEN_APPID=
WX_OPEN_SECRET=

# ── 微信支付 ────────────────────────────────
WX_PAY_MCH_ID=
WX_PAY_API_KEY=
WX_PAY_NOTIFY_URL=https://www.rockingwei.online/api/pay/wx-notify

# ── 短信 ────────────────────────────────────
SMS_PROVIDER=tencent
SMS_TENCENT_SECRET_ID=
SMS_TENCENT_SECRET_KEY=
SMS_TENCENT_APP_ID=

# ── 文件存储 ────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_LOCAL_BASE_URL=http://127.0.0.1:3000/uploads

# ── 日志 ────────────────────────────────────
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_FILE_DIR=./logs

# ── 限流 ────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ── CORS ────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://www.rockingwei.online

# ── 监控 / 告警 ─────────────────────────────
SENTRY_DSN=
ALERT_WEBHOOK_URL=
